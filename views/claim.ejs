<!-- Claim Hero -->
<section class="claim-hero">
  <div class="dir-container">
    <div class="claim-hero-inner">
      <div class="claim-copy">
        <div class="dir-hero-tag mb-3"><i class="bi bi-geo-alt-fill me-1"></i>Bristol, Vermont</div>
        <h1 class="claim-h1">Grow Your Bristol<br>Business</h1>
        <p class="claim-sub">Get found by locals, manage your customers, and grow with tools built for small businesses — all in one place.</p>
        <a href="<%= crmSignupUrl %>" class="dir-btn-primary dir-btn-lg">Get Started Free</a>
        <p class="claim-note">No credit card required &bull; Free listing included</p>
      </div>
      <div class="claim-tiers">
        <!-- Free -->
        <div class="claim-tier">
          <div class="claim-tier-header">
            <span class="claim-tier-name">Free Listing</span>
            <span class="claim-tier-price">$0</span>
          </div>
          <ul class="claim-tier-features">
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Listed in Bristol Digital Direct</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Business name, address & phone</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Category listing</li>
            <li><i class="bi bi-x-circle-fill text-muted me-2"></i>Photos & description</li>
            <li><i class="bi bi-x-circle-fill text-muted me-2"></i>CRM access</li>
          </ul>
        </div>

        <!-- Starter -->
        <div class="claim-tier claim-tier-featured">
          <div class="claim-tier-badge">Most Popular</div>
          <div class="claim-tier-header">
            <span class="claim-tier-name">Starter CRM</span>
            <span class="claim-tier-price">$29<span class="claim-tier-period">/mo</span></span>
          </div>
          <ul class="claim-tier-features">
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Enhanced directory listing</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Photos, description & hours</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Verified badge</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Full CRM — contacts, deals, calendar</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Conversation history</li>
          </ul>
          <a href="<%= crmSignupUrl %>" class="dir-btn-primary w-100 text-center mt-3 d-block">Get Started</a>
        </div>

        <!-- Growth -->
        <div class="claim-tier">
          <div class="claim-tier-header">
            <span class="claim-tier-name">Growth</span>
            <span class="claim-tier-price">$59<span class="claim-tier-period">/mo</span></span>
          </div>
          <ul class="claim-tier-features">
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Everything in Starter</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Analytics dashboard</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Email & SMS to clients</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Featured directory placement</li>
            <li><i class="bi bi-check-circle-fill text-success me-2"></i>Full conversation thread</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="dir-section">
  <div class="dir-container">
    <div class="dir-section-header center-block">
      <h2 class="dir-section-title">How It Works</h2>
    </div>
    <div class="claim-steps">
      <div class="claim-step">
        <div class="claim-step-num">1</div>
        <h3>Create your free account</h3>
        <p>Sign up in under 2 minutes. No credit card needed to get started.</p>
      </div>
      <div class="claim-step-arrow"><i class="bi bi-arrow-right"></i></div>
      <div class="claim-step">
        <div class="claim-step-num">2</div>
        <h3>Your listing goes live</h3>
        <p>Your business appears on Bristol Digital Direct immediately, visible to the whole community.</p>
      </div>
      <div class="claim-step-arrow"><i class="bi bi-arrow-right"></i></div>
      <div class="claim-step">
        <div class="claim-step-num">3</div>
        <h3>Grow with your CRM</h3>
        <p>Upgrade anytime to unlock contacts, deals, calendar, email and SMS — everything you need to grow.</p>
      </div>
    </div>
    <div class="text-center mt-5">
      <a href="<%= crmSignupUrl %>" class="dir-btn-primary dir-btn-lg">Get Your Business Listed</a>
    </div>
  </div>
</section>
