<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Bristol Digital Direct' %></title>
  <meta name="description" content="Discover the best local businesses in Bristol, Vermont. Your community guide to shops, restaurants, services and more.">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<!-- Nav -->
<nav class="dir-nav">
  <div class="dir-container">
    <a href="/" class="dir-logo">
      <div class="dir-logo-icon">B</div>
      <div>
        <div class="dir-logo-name">Bristol Digital Direct</div>
        <div class="dir-logo-sub">Bristol, Vermont</div>
      </div>
    </a>
    <div class="dir-nav-links">
      <a href="/search">Browse</a>
      <a href="/claim" class="dir-nav-cta">List Your Business</a>
    </div>
  </div>
</nav>

<!-- Page Content -->
<%- body %>

<!-- Footer -->
<footer class="dir-footer">
  <div class="dir-container">
    <div class="dir-footer-grid">
      <div>
        <div class="dir-logo-name mb-2">Bristol Digital Direct</div>
        <p class="text-muted small">Your guide to local businesses in Bristol, Vermont — Gateway to the Green Mountains.</p>
        <p class="text-muted small mt-2">Powered by <a href="https://bristolbusinesssystems.com" class="text-muted">Bristol Business Systems</a></p>
      </div>
      <div>
        <div class="dir-footer-heading">Explore</div>
        <ul class="dir-footer-links">
          <li><a href="/search">All Businesses</a></li>
          <li><a href="/category/restaurants-food">Restaurants</a></li>
          <li><a href="/category/retail-shopping">Shopping</a></li>
          <li><a href="/category/home-services">Home Services</a></li>
        </ul>
      </div>
      <div>
        <div class="dir-footer-heading">Business Owners</div>
        <ul class="dir-footer-links">
          <li><a href="/claim">Claim Your Listing</a></li>
          <li><a href="https://crm.bristolbusinesssystems.com">CRM Login</a></li>
          <li><a href="https://bristolbusinesssystems.com">About BBS</a></li>
        </ul>
      </div>
    </div>
    <div class="dir-footer-bottom">
      <span>&copy; <%= new Date().getFullYear() %> Bristol Digital Direct. Bristol, Vermont 05443.</span>
    </div>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
