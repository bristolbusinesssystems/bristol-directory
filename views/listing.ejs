<% if (listing.hero_image) { %>
  <img src="<%= listing.hero_image %>" alt="<%= listing.name %>" class="dir-listing-hero">
<% } else { %>
  <div class="dir-listing-hero-placeholder"><i class="bi bi-building"></i></div>
<% } %>

<section class="dir-section">
  <div class="dir-container">
    <div class="row g-4">
      <div class="col-lg-8">
        <!-- Header -->
        <div class="mb-4">
          <% if (listing.category_name) { %>
            <a href="/category/<%= listing.category_slug %>" class="dir-listing-cat d-inline-block mb-2"><%= listing.category_name %></a>
          <% } %>
          <h1 class="dir-page-title" style="color:var(--text)"><%= listing.name %></h1>
          <div class="d-flex gap-3 mt-2 flex-wrap">
            <% if (listing.is_verified) { %><span class="badge bg-success"><i class="bi bi-patch-check-fill me-1"></i>Verified</span><% } %>
            <% if (listing.is_featured) { %><span class="badge" style="background:var(--amber)"><i class="bi bi-star-fill me-1"></i>Featured</span><% } %>
          </div>
        </div>

        <% if (listing.description) { %>
          <div class="dir-detail-card">
            <div class="dir-detail-label">About</div>
            <p style="margin:0;line-height:1.7"><%= listing.description %></p>
          </div>
        <% } else if (listing.short_description) { %>
          <div class="dir-detail-card">
            <p style="margin:0;line-height:1.7"><%= listing.short_description %></p>
          </div>
        <% } %>

        <% if (!listing.is_paid) { %>
          <div class="dir-detail-card" style="border-color:var(--green);background:var(--green-soft)">
            <h5 style="color:var(--green);margin-bottom:8px"><i class="bi bi-star-fill me-2"></i>Is this your business?</h5>
            <p style="margin-bottom:12px;color:var(--text-soft)">Claim this listing to add photos, description, opening hours and get full CRM access.</p>
            <a href="/claim?listing_id=<%= listing.id %>" class="dir-btn-primary">Claim Your Listing</a>
          </div>
        <% } %>
      </div>

      <div class="col-lg-4">
        <div class="dir-detail-card">
          <% if (listing.phone) { %>
            <div class="mb-3">
              <div class="dir-detail-label">Phone</div>
              <a href="tel:<%= listing.phone %>" style="color:var(--green);font-weight:600"><i class="bi bi-telephone me-1"></i><%= listing.phone %></a>
            </div>
          <% } %>
          <% if (listing.website) { %>
            <div class="mb-3">
              <div class="dir-detail-label">Website</div>
              <a href="https://<%= listing.website.replace('https://','').replace('http://','') %>" target="_blank" style="color:var(--green);font-weight:600"><i class="bi bi-globe me-1"></i><%= listing.website %></a>
            </div>
          <% } %>
          <% if (listing.email) { %>
            <div class="mb-3">
              <div class="dir-detail-label">Email</div>
              <a href="mailto:<%= listing.email %>" style="color:var(--green);font-weight:600"><i class="bi bi-envelope me-1"></i><%= listing.email %></a>
            </div>
          <% } %>
          <div class="mb-0">
            <div class="dir-detail-label">Location</div>
            <span><i class="bi bi-geo-alt me-1 text-muted"></i><%= listing.address ? listing.address + ', ' : '' %><%= listing.city %>, <%= listing.state %> <%= listing.zip %></span>
          </div>
        </div>

        <%
          var hourDays = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday'];
          var hrs = listing.hours || {};
          var hasHours = hourDays.some(function(d) { return hrs[d] && (hrs[d].open || hrs[d].closed); });
        %>
        <% if (hasHours) { %>
        <div class="dir-detail-card">
          <div class="dir-detail-label d-flex align-items-center justify-content-between">
            <span>Hours</span>
            <% if (listing.is_open_now === true) { %>
              <span class="badge bg-success" style="font-size:11px"><i class="bi bi-circle-fill me-1" style="font-size:8px"></i>Open Now</span>
            <% } else if (listing.is_open_now === false) { %>
              <span class="badge bg-danger" style="font-size:11px">Closed</span>
            <% } %>
          </div>
          <table class="w-100" style="font-size:14px;margin-top:8px">
            <% hourDays.forEach(function(day) {
              var dh = hrs[day];
              if (!dh) return;
              var isToday = (day === today);
            %>
            <tr style="<%= isToday ? 'font-weight:700' : '' %>">
              <td style="width:45%;padding:3px 0;color:<%= isToday ? 'var(--green)' : 'var(--text)' %>">
                <%= day.charAt(0).toUpperCase() + day.slice(1) %>
              </td>
              <td style="padding:3px 0;color:var(--text-soft)">
                <% if (dh.closed) { %>
                  <span style="color:#999">Closed</span>
                <% } else if (dh.open && dh.close) { %>
                  <%= dh.open %> – <%= dh.close %>
                <% } else { %>
                  <span style="color:#ccc">—</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
