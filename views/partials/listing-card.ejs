<a href="/listing/<%= listing.slug %>" class="dir-listing-card <%= listing.is_paid ? 'dir-listing-paid' : '' %>">
  <div class="dir-listing-img">
    <% if (listing.hero_image) { %>
      <img src="<%= listing.hero_image %>" alt="<%= listing.name %>">
    <% } else { %>
      <div class="dir-listing-img-placeholder">
        <i class="bi bi-building"></i>
      </div>
    <% } %>
    <% if (listing.is_verified) { %>
      <span class="dir-verified-badge"><i class="bi bi-patch-check-fill me-1"></i>Verified</span>
    <% } %>
    <% if (listing.is_featured) { %>
      <span class="dir-featured-badge"><i class="bi bi-star-fill me-1"></i>Featured</span>
    <% } %>
  </div>
  <div class="dir-listing-body">
    <div class="dir-listing-cat"><%= listing.category_name || '' %></div>
    <div class="dir-listing-name"><%= listing.name %></div>
    <% if (listing.short_description) { %>
      <div class="dir-listing-desc"><%= listing.short_description %></div>
    <% } %>
    <div class="dir-listing-meta">
      <span><i class="bi bi-geo-alt me-1"></i><%= listing.city %>, VT</span>
      <% if (listing.phone) { %><span><i class="bi bi-telephone me-1"></i><%= listing.phone %></span><% } %>
    </div>
  </div>
</a>
